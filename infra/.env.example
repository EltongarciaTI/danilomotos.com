# Copie pra .env e preencha — .env NUNCA vai pro git (já no .gitignore)
# Pra gerar JWT_SECRET: openssl rand -hex 64

# Postgres
POSTGRES_USER=danilomotos
POSTGRES_PASSWORD=troque-essa-senha-forte
POSTGRES_DB=danilomotos

# API
JWT_SECRET=cole-aqui-64-bytes-hex-gerados-com-openssl
COOKIE_DOMAIN=danilomotos.com
ALLOWED_ORIGIN=https://danilomotos.com

# Cloudflare Tunnel (cria em dash.cloudflare.com → Zero Trust → Networks → Tunnels)
# Nome sugerido: danilomotos-tunnel
# O token aparece quando você clica em "Install connector → Docker"
CF_TUNNEL_TOKEN=cole-aqui-o-tunnel-token-do-cloudflare

# Backups
BACKUP_KEEP_DAYS=30
